# Leave unset in local dev — the Vite dev server proxies /api and /health
# to PLUMBLINE_API_TARGET (default http://localhost:4000).
#
# Set VITE_API_BASE_URL to an absolute URL only when the frontend talks to
# a backend on a different origin (e.g. a deployed build on Vercel).
# VITE_API_BASE_URL=
