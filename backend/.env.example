PORT=4000
MONGO_URL=mongodb://localhost:27017/plumbline
UPLOADS_DIR=./uploads
ANTHROPIC_API_KEY=

# Optional — override the default model. Use claude-haiku-4-5-20251001 for cheap demos
# (~10x cheaper than Opus 4.7, slightly lower verdict quality).
ANTHROPIC_MODEL=claude-opus-4-7

# Optional — pino log level (info, debug, warn, error). Defaults to info.
LOG_LEVEL=info
